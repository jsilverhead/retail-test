Accept: application/json
Content-Type: application/json

{
  "product": 1,
  "taxNumber": "GR123456789",
  "couponCode": "D15"
}

### Calculate Price | Iphone | GR country | No coupon | Success
POST http://127.0.0.1:8337/calculate-price
Accept: application/json
Content-Type: application/json

{
  "product": 1,
  "taxNumber": "GR123456789",
  "couponCode": null
}

### Calculate Price | Iphone | FAIL country | No coupon | Fail
POST http://127.0.0.1:8337/calculate-price
Accept: application/json
Content-Type: application/json

{
  "product": 1,
  "taxNumber": "FAIL",
  "couponCode": null
}

> {%
    client.test("Response status is 400", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
%}

